# ===================================
# Food Delivery - Environment Variables
# Copy to .env and fill in actual values
# ===================================

# PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/user_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Kafka
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# JWT (User Service only)
JWT_SECRET=change-me-in-production-must-be-at-least-256-bits

# Internal Service URLs
RESTAURANT_SERVICE_URL=http://localhost:8082
USER_SERVICE_URL=http://localhost:8081
ORDER_SERVICE_URL=http://localhost:8083

# Go Dispatch Service
SERVER_PORT=8080
REDIS_ADDR=localhost:6379
KAFKA_BROKERS=localhost:9092

# Node.js Notification Service
PORT=8080
REDIS_URL=redis://localhost:6379

# Payment
PAYMENT_GATEWAY_MODE=mock

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
